# Django
DJANGO_SECRET_KEY=change-me-to-a-long-random-secret
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost,testapp.begintimes.by,178.163.244.93

# Database mode:
# - For local sqlite use DB_ENGINE=django.db.backends.sqlite3 and set SQLITE_PATH
# - For postgres use DB_ENGINE=django.db.backends.postgresql and DB_* values below
