from django.shortcuts import render, get_object_or_404, redirect
from django.contrib.auth.decorators import login_required
from django.db.models import OuterRef, Subquery

from .models import Course, Lesson, Question, LessonAttempt

PASS_THRESHOLD = 80  # %


@login_required
def course_list(request):
    courses = Course.objects.all().order_by("-id")
    return render(request, "courses/course_list.html", {"courses": courses})


@login_required
def course_detail(request, course_id: int):
    course = get_object_or_404(Course, pk=course_id)

    lessons = Lesson.objects.filter(course=course).order_by("order", "id")

    last_attempt = LessonAttempt.objects.filter(
        user=request.user,
        lesson=OuterRef("pk"),
    ).order_by("-created_at")

    lessons = lessons.annotate(
        last_score=Subquery(last_attempt.values("score")[:1]),
        last_passed=Subquery(last_attempt.values("passed")[:1]),
    )

    return render(
        request,
        "courses/course_detail.html",
        {"course": course, "lessons": lessons, "pass_threshold": PASS_THRESHOLD},
    )


@login_required
def lesson_detail(request, course_id: int, lesson_id: int):
    course = get_object_or_404(Course, pk=course_id)
    lesson = get_object_or_404(Lesson, pk=lesson_id, course=course)

    last_attempt = LessonAttempt.objects.filter(user=request.user, lesson=lesson).first()

    lessons = list(Lesson.objects.filter(course=course).order_by("order", "id"))
    idx = next((i for i, x in enumerate(lessons) if x.id == lesson.id), None)
    next_lesson = lessons[idx + 1] if idx is not None and idx + 1 < len(lessons) else None

    questions_count = lesson.questions.count()

    return render(
        request,
        "courses/lesson_detail.html",
        {
            "course": course,
            "lesson": lesson,
            "next_lesson": next_lesson,
            "last_attempt": last_attempt,
            "questions_count": questions_count,
            "pass_threshold": PASS_THRESHOLD,
        },
    )


@login_required
def lesson_test(request, course_id: int, lesson_id: int):
    course = get_object_or_404(Course, pk=course_id)
    lesson = get_object_or_404(Lesson, pk=lesson_id, course=course)

    questions = lesson.questions.all().order_by("id")

    if request.method == "POST":
        total = questions.count()
        correct = 0

        for q in questions:
            chosen = request.POST.get(f"q_{q.id}")  # 'A'/'B'/'C'
            if chosen and chosen.upper() == q.correct_answer:
                correct += 1

        score = int((correct / total) * 100) if total else 0
        passed = score >= PASS_THRESHOLD

        LessonAttempt.objects.create(
            user=request.user,
            lesson=lesson,
            score=score,
            correct=correct,
            total=total,
            passed=passed,
        )

        return redirect("courses:lesson_result", course_id=course.id, lesson_id=lesson.id)

    return render(
        request,
        "courses/lesson_test.html",
        {"course": course, "lesson": lesson, "questions": questions},
    )


@login_required
def lesson_result(request, course_id: int, lesson_id: int):
    course = get_object_or_404(Course, pk=course_id)
    lesson = get_object_or_404(Lesson, pk=lesson_id, course=course)

    attempt = LessonAttempt.objects.filter(user=request.user, lesson=lesson).first()

    return render(
        request,
        "courses/lesson_result.html",
        {"course": course, "lesson": lesson, "attempt": attempt, "pass_threshold": PASS_THRESHOLD},
    )
